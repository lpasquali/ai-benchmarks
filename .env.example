# RUNE — Docker Compose Environment Template
# Copy this to .env to customise your local development setup.
# IMPORTANT: Never commit your real .env file to source control.

# PostgreSQL Configuration
POSTGRES_USER=rune
POSTGRES_PASSWORD=runesecret
POSTGRES_DB=rune

# RUNE API Configuration
RUNE_API_AUTH_DISABLED=1
RUNE_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# External Services
GITHUB_TOKEN=
