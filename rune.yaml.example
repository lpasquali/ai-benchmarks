# rune.yaml.example — copy this to rune.yaml and customise.
# Or run:  rune init
#
# https://github.com/lpasquali/rune
#
# Precedence: CLI flags > env vars > ./rune.yaml > ~/.rune/config.yaml > defaults
#
# IMPORTANT: Never store secrets in this file (API tokens, VAST_API_KEY).
#            Secrets must remain in environment variables only.
#
# Activate a profile:
#   rune --profile production run-benchmark
#   RUNE_PROFILE=production rune run-benchmark
#
# Show effective config:
#   rune config

version: "1"

defaults:
  # Model and benchmark
  model: llama3.1:8b
  question: "What is unhealthy in this Kubernetes cluster?"
  kubeconfig: ~/.kube/config

  # Execution backend (local | http)
  backend: local

  # Ollama settings
  ollama_warmup: true
  ollama_warmup_timeout: 300

  # Vast.ai settings
  vastai: false
  vastai_stop_instance: true
  template_hash: c166c11f035d3a97871a23bd32ca6aba

profiles:
  # Full Vast.ai provisioning for production benchmarks
  production:
    vastai: true
    min_dph: 2.3
    max_dph: 3.0
    reliability: 0.99
    ollama_warmup: true

  # Cheaper Vast.ai instances for staging / QA
  staging:
    vastai: true
    min_dph: 1.0
    max_dph: 2.0
    reliability: 0.95
    ollama_warmup: true

  # Local Ollama server, no Vast.ai
  local:
    vastai: false
    ollama_url: http://localhost:11434
    ollama_warmup: false

  # HTTP backend mode — rune submits jobs to a running API server
  ci:
    backend: http
    api_base_url: http://rune-api:8080
    vastai: false
    ollama_warmup: false

  # Test / mock environment
  test:
    vastai: false
    ollama_url: http://localhost:11434
    ollama_warmup: false
    model: llama3.1:8b
